    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
